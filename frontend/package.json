{
  "name": "codereview-agent-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm run typecheck && vite build",
    "check": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run test && pnpm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b --force",
    "test": "vitest run"
  },
  "dependencies": {
    "element-plus": "2.14.2",
    "highlight.js": "^11.11.1",
    "pinia": "3.0.4",
    "vue": "3.5.39",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.2",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/test-utils": "2.4.11",
    "eslint": "10.6.0",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.3",
    "vitest": "4.1.9",
    "vue-tsc": "3.3.6"
  }
}

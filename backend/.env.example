APP_NAME=CodeReview Agent
APP_VERSION=0.1.0
APP_ENV=dev
DEBUG=false
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=["http://localhost:5173"]
LOG_LEVEL=INFO
LOG_JSON=true
REQUEST_ID_HEADER=X-Request-ID
DATABASE_URL=postgresql+asyncpg://codereview:codereview@localhost:5432/codereview
REDIS_URL=redis://localhost:6379/0
TASK_EVENT_RETENTION_DAYS=7
TASK_EVENT_STREAM_MAX_LENGTH=10000
SSE_HEARTBEAT_SECONDS=15
SSE_EVENT_BATCH_SIZE=100
JWT_SECRET_KEY=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
JWT_ISSUER=codereview-agent
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
HEALTH_DEPENDENCY_TIMEOUT_SECONDS=2.0
UPLOAD_ROOT=var/uploads
MAX_PROJECT_SIZE_MB=300
MAX_SINGLE_FILE_MB=3
MAX_FILE_COUNT=5000
MAX_TOTAL_LINES=150000
MAX_RELATIVE_PATH_LENGTH=512
ENABLED_LANGUAGES=["java","python"]
